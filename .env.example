# ==============================================================================
# GPGLB 环境变量配置模板
# 使用说明: 复制此文件为 .env 并填入你的配置
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. OpenAI API配置
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# API调用参数
API_TEMPERATURE=0.3              # 温度参数（0-2），越低越确定性
API_MAX_TOKENS=200               # 最大生成token数
API_CONCURRENCY_LIMIT=20         # 并发请求数限制

# ------------------------------------------------------------------------------
# 2. 图网络参数
# ------------------------------------------------------------------------------
# 图构建参数
GRAPH_TYPE=visibility            # 图类型: euclidean | street | visibility
K_NEIGHBORS=8                    # k近邻数量（euclidean模式）
MAX_DISTANCE=500                 # 最大连接距离（米）

# 节点特征维度
NODE_FEATURE_DIM=13              # 节点特征向量维度

# ------------------------------------------------------------------------------
# 3. GNN模型参数
# ------------------------------------------------------------------------------
GNN_HIDDEN_DIM=64                # 隐藏层维度
GNN_NUM_LAYERS=3                 # GCN层数
GNN_HEADS=4                      # GAT注意力头数
GNN_DROPOUT=0.3                  # Dropout率

# 训练参数
GNN_EPOCHS=200                   # 训练轮数
GNN_LEARNING_RATE=0.001          # 学习率
GNN_BATCH_SIZE=512               # 批次大小
GNN_EARLY_STOPPING=20            # 早停轮数

# ------------------------------------------------------------------------------
# 4. LLM-GLN参数
# ------------------------------------------------------------------------------
# 模拟参数
LLM_TRIGGER_PROB=1.0             # LLM触发概率（1.0=所有节点都用LLM）
SAVE_REASONING=true              # 是否保存LLM推理过程
CACHE_PROMPTS=true               # 是否缓存相似Prompt结果

# Agent参数
OWNER_TYPE_DIST=0.6,0.2,0.2      # 业主类型分布（resident, investor, commercial）

# ------------------------------------------------------------------------------
# 5. 模拟参数
# ------------------------------------------------------------------------------
START_YEAR=2022                  # 模拟起始年份
END_YEAR=2030                    # 模拟结束年份
SAVE_INTERVAL=1                  # 状态保存间隔（年）

# 政策场景
POLICY_SCENARIO=trend            # 政策场景: trend | cbd | tod

# ------------------------------------------------------------------------------
# 6. 数据路径配置
# ------------------------------------------------------------------------------
# 原始数据路径
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_EXTERNAL_DIR=./data/external

# 输出路径
RESULTS_DIR=./results
FIGURES_DIR=./results/figures
CHECKPOINTS_DIR=./models/checkpoints
LOGS_DIR=./logs

# ------------------------------------------------------------------------------
# 7. 西宁市特定配置
# ------------------------------------------------------------------------------
CITY_NAME=西宁市
CITY_CENTER_LON=101.7782          # 城市中心经度
CITY_CENTER_LAT=36.6171           # 城市中心纬度
CITY_EPSG=32649                   # UTM投影坐标系（UTM 49N for 西宁）

# CBD定义（距中心点距离）
CBD_RADIUS=2000                   # CBD半径（米）

# 地铁站缓冲区
METRO_BUFFER=800                  # 地铁站影响范围（米）

# ------------------------------------------------------------------------------
# 8. 可视化参数
# ------------------------------------------------------------------------------
VIS_DPI=300                       # 图像分辨率
VIS_FIGSIZE=12,8                  # 图像大小（英寸）
VIS_CMAP=RdYlGn_r                 # 色彩映射（质量：红=差，绿=好）

# 地图参数
MAP_TILE_PROVIDER=OpenStreetMap   # 底图提供商
MAP_ZOOM_START=12                 # 初始缩放级别

# ------------------------------------------------------------------------------
# 9. 性能优化
# ------------------------------------------------------------------------------
NUM_WORKERS=4                     # 数据加载并发数
DEVICE=cuda                       # 计算设备: cuda | cpu | mps(Mac)

# 内存优化
BATCH_PROCESSING=true             # 是否分批处理大规模图
BATCH_SIZE_NODES=1000             # 每批处理的节点数

# ------------------------------------------------------------------------------
# 10. 代理设置（国内用户可能需要）
# ------------------------------------------------------------------------------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ------------------------------------------------------------------------------
# 11. 日志配置
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO                    # 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s

# ------------------------------------------------------------------------------
# 12. 实验配置
# ------------------------------------------------------------------------------
EXPERIMENT_NAME=gpglb_xining      # 实验名称
RANDOM_SEED=42                    # 随机种子（可复现性）

# 对比实验开关
RUN_GNN_BASELINE=true             # 是否运行GNN基线
RUN_LLM_GLN=true                  # 是否运行LLM-GLN
RUN_ABM=false                     # 是否运行传统ABM（可选）
RUN_CA_ABM=false                  # 是否运行CA-ABM（可选）

# ==============================================================================
# 配置说明
# ==============================================================================
#
# 快速开始配置（小规模测试）:
# - OPENAI_MODEL=gpt-4o-mini
# - API_CONCURRENCY_LIMIT=10
# - LLM_TRIGGER_PROB=0.3
# - GNN_EPOCHS=50
#
# 生产配置（完整模拟）:
# - OPENAI_MODEL=gpt-4o-mini
# - API_CONCURRENCY_LIMIT=20
# - LLM_TRIGGER_PROB=1.0
# - GNN_EPOCHS=200
#
# 高质量配置（研究用）:
# - OPENAI_MODEL=gpt-4o
# - API_CONCURRENCY_LIMIT=5
# - LLM_TRIGGER_PROB=1.0
# - GNN_EPOCHS=500
#
# ==============================================================================
