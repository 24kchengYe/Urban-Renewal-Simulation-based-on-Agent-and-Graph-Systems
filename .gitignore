# ==============================================================================
# GPGLB .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# 2. 环境变量和配置
# ------------------------------------------------------------------------------
.env
.env.local
*.env
config/local_*.yaml

# ------------------------------------------------------------------------------
# 3. 数据文件（大文件不上传）
# ------------------------------------------------------------------------------
data/raw/*.shp
data/raw/*.shx
data/raw/*.dbf
data/raw/*.prj
data/raw/*.cpg
data/raw/*.xml
data/raw/*.csv
data/external/*.csv
data/external/*.geojson
data/processed/*.pkl
data/processed/*.h5
data/processed/*.parquet

# 但保留示例数据
!data/raw/example_*.shp
!data/external/example_*.csv

# ------------------------------------------------------------------------------
# 4. 模型文件
# ------------------------------------------------------------------------------
models/checkpoints/*.pth
models/checkpoints/*.pt
models/checkpoints/*.pkl
*.h5
*.hdf5

# 但保留README
!models/checkpoints/README.md

# ------------------------------------------------------------------------------
# 5. 实验结果
# ------------------------------------------------------------------------------
results/*.pkl
results/figures/*.png
results/figures/*.jpg
results/figures/*.gif
results/figures/*.html
results/logs/*.log
results/logs/*.txt

# 但保留README和示例图
!results/figures/README.md
!results/figures/example_*.png

# ------------------------------------------------------------------------------
# 6. Jupyter Notebook
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# Jupyter Notebook临时文件
.~*.ipynb

# ------------------------------------------------------------------------------
# 7. IDE
# ------------------------------------------------------------------------------
# PyCharm
.idea/
*.iml
*.iws

# VS Code
.vscode/
*.code-workspace

# Spyder
.spyderproject
.spyproject

# ------------------------------------------------------------------------------
# 8. 操作系统
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------------------------
# 9. 日志文件
# ------------------------------------------------------------------------------
logs/
*.log
*.log.*

# ------------------------------------------------------------------------------
# 10. 临时文件
# ------------------------------------------------------------------------------
tmp/
temp/
cache/
*.tmp
*.bak
*.swp
*.swo

# ------------------------------------------------------------------------------
# 11. 测试覆盖率
# ------------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.tox/
.pytest_cache/

# ------------------------------------------------------------------------------
# 12. 文档构建
# ------------------------------------------------------------------------------
docs/_build/
docs/_static/
docs/_templates/

# ------------------------------------------------------------------------------
# 13. 其他
# ------------------------------------------------------------------------------
# API密钥和凭证
*.key
*.pem
credentials.json

# 大型数据集（超过100MB）
*.zip
*.tar
*.tar.gz
*.rar

# 数据库文件
*.db
*.sqlite
*.sqlite3

# ==============================================================================
# 提示：
# - 如果你有需要提交的大文件，考虑使用Git LFS
# - 敏感信息（API密钥等）务必不要上传到Git
# ==============================================================================
